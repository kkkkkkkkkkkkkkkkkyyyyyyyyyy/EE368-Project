<launch>
    <arg name="marker_size" default="0.052" /> 
    <arg name="marker_id" default="58" />

    <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen" >
        <param name="video_device" value="/dev/video4" />
        <param name="image_width" value="640" />
        <param name="image_height" value="480" />
        <param name="pixel_format" value="yuyv" />
        <param name="camera_frame_id" value="usb_cam" />
        <param name="camera_name" value="usb_cam" />
        <param name="camera_info_url" value="file:///home/lc/.ros/camera_info/head_camera.yaml" />
    </node>

    <node pkg="aruco_ros" type="single" name="aruco_single">
        <remap from="/camera_info" to="/usb_cam/camera_info" />
        <remap from="/image" to="/usb_cam/image_raw" />
        
        <param name="image_is_rectified" value="True"/>
        <param name="marker_size" value="$(arg marker_size)"/>
        <param name="marker_id" value="$(arg marker_id)"/>
        <param name="reference_frame" value="usb_cam"/> 
        <param name="camera_frame" value="usb_cam"/>
        <param name="marker_frame" value="aruco_marker_frame" /> 
    </node>

    <include file="$(find easy_handeye)/launch/calibrate.launch">
        <arg name="move_group" value="arm" /> 
        <arg name="eye_on_hand" value="true" />
        <arg name="robot_base_frame" value="base_link" />
        <arg name="robot_effector_frame" value="end_effector_link" />
        <arg name="tracking_base_frame" value="usb_cam" />
        <arg name="tracking_marker_frame" value="aruco_marker_frame" />
        <arg name="freehand_robot_movement" value="true" />
    </include>
</launch>